# ══════════════════════════════════════════════════════════════════════════════
# ScriptStream — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ─── AI (Required) ────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXX

# ─── MongoDB (Required) ──────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Create Free Cluster → Connect → Driver
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/scriptstream?retryWrites=true&w=majority 

# ─── JWT Secret (Required) ───────────────────────────────────────────────────
# Any random string — used to sign auth tokens
JWT_SECRET=your_super_secret_jwt_key_change_this

# ─── ChromaDB (Required) ─────────────────────────────────────────────────────
# The JavaScript SDK requires a running ChromaDB server.
# Leave EMPTY to default to http://localhost:8000 (Requires Docker: `docker run -p 8000:8000 chromadb/chroma`)
# Or set to a remote URL for production.
CHROMA_URL=

# ─── Email via Nodemailer (Optional) ─────────────────────────────────────────
# Leave SMTP_HOST EMPTY to auto-use Ethereal Mail (free dev inbox)
# For Gmail: use App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL_FROM=ScriptStream <noreply@scriptstream.ai>

# ─── WhatsApp via Twilio (Optional) ──────────────────────────────────────────
# Get from: https://www.twilio.com/console
# Sandbox number for dev: whatsapp:+14155238886
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
